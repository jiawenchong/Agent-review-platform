# ProphetAI 憑證 — 只需填一次，之後每次啟動後端會自動讀取，不用再手動 set 或執行任何腳本。
#
# 使用方式：
#   1. 複製這份檔案為 credentials.env（同資料夾內，檔名去掉 .example）
#   2. 填入下面四組憑證（每個 Agent 各自獨立，金鑰與 agent id 不共用）
#   3. 直接啟動後端即可（uvicorn / start-lan.bat 都會自動讀到）：
#        cd backend
#        python -m uvicorn app.main:app --host 0.0.0.0 --port 8010
#
# credentials.env 本身已被 .gitignore 排除，絕對不會被 commit。
# 只有這份 .example 範本（內容留空）會進版控。
#
# ★ 只需要填這四組 API key / agent id。其他東西（AD 登入、JWT、bootstrap admin）
#   都已內建預設值，不用設定：
#     · AD 伺服器/UPN 後綴/base DN → 程式內建公司值（10.10.10.2 等），直接用 AD 帳密登入
#     · JWT_SECRET → 第一次啟動自動產生並存到 backend/.jwt_secret（已 gitignore）
#     · 第一個管理員 → 內建 K20076，第一次登入自動成為 admin
#   需要覆寫時才在這個檔案加對應變數（見檔尾「進階覆寫」）。

# ── 文件審核 Agent（AI 評審中心：綠燈/紅燈/待補件） ──────────────────
COMPANY_REVIEW_KEY=
COMPANY_REVIEW_AGENT=

# ── 流程圖生成 Agent（AS IS / TO BE Mermaid 流程圖） ────────────────
COMPANY_FLOWCHART_KEY=
COMPANY_FLOWCHART_AGENT=

# ── 申訴合理性 Agent（Closed-Loop 停滯申訴判讀） ──────────────────────
COMPANY_APPEAL_KEY=
COMPANY_APPEAL_AGENT=

# ── 驗證報告 Agent（AI 訪談 + PPTX 生成） ────────────────────────────
COMPANY_VALIDATION_KEY=
COMPANY_VALIDATION_AGENT=

# ═══ 進階覆寫（通常不用動；要用時把 # 拿掉再填值）═════════════════════
# AD 登入（預設已內建公司值，只有站點不同才需要改；APP_AD_SERVER= 留空 = 關閉 AD）
# APP_AD_SERVER=10.10.10.2
# APP_AD_UPN_SUFFIX=kh.asegroup.com,aseglobal.com    ← 逗號分隔，依序嘗試
# APP_AD_BASE_DN=DC=ase,DC=com,DC=tw
# APP_AD_DOMAIN=KH
# APP_AD_PORT=636
# APP_AD_TLS_VERIFY=false
#
# 第一個管理員的員工編號（預設 K20076；換人時改這行）
# APP_BOOTSTRAP_ADMIN_EMPNO=K20076
#
# JWT 簽章金鑰（預設自動產生；想固定值才填，產生指令：
#   python -c "import secrets; print(secrets.token_hex(32))"）
# JWT_SECRET=
