# ProphetAI 憑證 — 只需填一次，之後每次啟動後端會自動讀取，不用再手動 set 或執行任何腳本。
#
# 使用方式：
#   1. 複製這份檔案為 credentials.env（同資料夾內，檔名去掉 .example）
#   2. 填入下面三組憑證（每個 Agent 各自獨立，金鑰與 agent id 不共用）
#   3. 直接啟動後端即可（uvicorn / start-lan.bat 都會自動讀到）：
#        cd backend
#        python -m uvicorn app.main:app --host 0.0.0.0 --port 8010
#
# credentials.env 本身已被 .gitignore 排除，絕對不會被 commit。
# 只有這份 .example 範本（內容留空）會進版控。
#
# 如果 host 本機另外用環境變數（set / export）設定了同名變數，那組環境變數優先，
# 這個檔案裡的值會被忽略 — 不會互相覆蓋衝突。

# ── 文件審核 Agent（AI 評審中心：綠燈/紅燈/待補件） ──────────────────
COMPANY_REVIEW_KEY=
COMPANY_REVIEW_AGENT=

# ── 流程圖生成 Agent（AS IS / TO BE Mermaid 流程圖） ────────────────
COMPANY_FLOWCHART_KEY=
COMPANY_FLOWCHART_AGENT=

# ── 申訴合理性 Agent（Closed-Loop 停滯申訴判讀） ──────────────────────
COMPANY_APPEAL_KEY=
COMPANY_APPEAL_AGENT=

# ── 驗證報告 Agent（AI 訪談 + PPTX 生成） ────────────────────────────
COMPANY_VALIDATION_KEY=
COMPANY_VALIDATION_AGENT=

# ── AD 登入設定（LDAPS SIMPLE bind） ─────────────────────────────────
# 填入後，後端在登入時先向 AD 驗證；AD 不可達時自動退回本機 bcrypt hash。
# 若整組留空，則完全跳過 LDAP，只用 password_hash（離線/測試模式）。
# 這些設定也可以改用 APP_ 前綴的環境變數（如 APP_AD_SERVER）設定。
# 注意：這些值不敏感，但集中放這裡方便管理。
APP_AD_SERVER=              # e.g. 10.10.10.2
APP_AD_UPN_SUFFIX=          # e.g. kh.asegroup.com  →  empno@kh.asegroup.com
APP_AD_PORT=636
APP_AD_USE_SSL=true
APP_AD_TLS_VERIFY=false     # false = 接受內部自簽 AD 憑證（常見 on-prem 設定）

# ── JWT Session Cookie 金鑰（敏感！勿 commit 真實值） ──────────────────
# 產生指令：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── 首次啟動 Bootstrap Admin（建立第一個管理員帳號）────────────────────
# 填入後，後端啟動時若該 empno 的使用者不存在，會自動建立一個 role=admin 的本機帳號。
# 建立成功後這三行可刪除或保留（empno 已存在 → 直接略過，不會覆蓋現有帳號）。
# 登入時用 empno + BOOTSTRAP_ADMIN_PASSWORD（若同時有 AD，AD 驗證優先）。
BOOTSTRAP_ADMIN_EMPNO=          # 你的員工編號，例如 A123456
BOOTSTRAP_ADMIN_NAME=           # 顯示名稱，例如 王小明
BOOTSTRAP_ADMIN_PASSWORD=       # 本機登入密碼（只存 bcrypt hash，原文不進 DB）
