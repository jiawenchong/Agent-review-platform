@echo off
REM ProphetAI 憑證設定範本(Windows)。
REM
REM 使用方式:
REM   1. 複製這份檔案為 credentials.bat(同資料夾內,檔名去掉 .example)
REM   2. 填入下面三組憑證(每個 Agent 各自獨立,金鑰與 agent id 不共用)
REM   3. 啟動後端前先執行這個 .bat:
REM        cd backend
REM        credentials.bat
REM        python -m uvicorn app.main:app --host 0.0.0.0 --port 8010
REM
REM credentials.bat 本身已被 .gitignore 排除,絕對不會被 commit。
REM 只有這份 .example 範本(內容留空)會進版控。

REM ── 文件審核 Agent(AI 評審中心:綠燈/紅燈/待補件) ──────────────────
set COMPANY_REVIEW_KEY=
set COMPANY_REVIEW_AGENT=

REM ── 流程圖生成 Agent(AS IS / TO BE Mermaid 流程圖) ──────────────
set COMPANY_FLOWCHART_KEY=
set COMPANY_FLOWCHART_AGENT=

REM ── 申訴合理性 Agent(Closed-Loop 停滯申訴判讀) ────────────────────
set COMPANY_APPEAL_KEY=
set COMPANY_APPEAL_AGENT=
