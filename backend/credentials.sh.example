#!/usr/bin/env bash
# ProphetAI 憑證設定範本(Mac/Linux)。
#
# 使用方式:
#   1. 複製這份檔案為 credentials.sh(同資料夾內,檔名去掉 .example)
#   2. 填入下面三組憑證(每個 Agent 各自獨立,金鑰與 agent id 不共用)
#   3. 啟動後端前先 source 這個檔案:
#        cd backend
#        source credentials.sh
#        python -m uvicorn app.main:app --host 0.0.0.0 --port 8010
#
# credentials.sh 本身已被 .gitignore 排除,絕對不會被 commit。
# 只有這份 .example 範本(內容留空)會進版控。

# ── 文件審核 Agent(AI 評審中心:綠燈/紅燈/待補件) ──────────────────
export COMPANY_REVIEW_KEY=
export COMPANY_REVIEW_AGENT=

# ── 流程圖生成 Agent(AS IS / TO BE Mermaid 流程圖) ──────────────
export COMPANY_FLOWCHART_KEY=
export COMPANY_FLOWCHART_AGENT=

# ── 申訴合理性 Agent(Closed-Loop 停滯申訴判讀) ────────────────────
export COMPANY_APPEAL_KEY=
export COMPANY_APPEAL_AGENT=
