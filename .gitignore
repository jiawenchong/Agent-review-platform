# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
# NOTE: dist/ is intentionally COMMITTED — it is the prebuilt frontend served by
# FastAPI so the app runs with Python only (no Node on the host). Do NOT ignore
# it, or rebuilt hashed assets go missing from the repo and the UI 404s.
dist-ssr
*.local

# Real ProphetAI credentials — NEVER commit. Copy credentials.env.example →
# credentials.env (recommended: fill once, auto-loaded on every future start)
# or credentials.bat/.sh (manual `set`/`source` each launch) and fill in
# locally; only the .example files are tracked.
backend/credentials.env
backend/credentials.bat
backend/credentials.sh

# Auto-generated JWT signing secret (created on first backend startup) — never commit
backend/.jwt_secret

# Generated validation-report artifacts (per-session PPTX/PDF temp output)
backend/generated_reports/

# Claude Code agent worktrees (created by isolation: "worktree" runs, ephemeral)
.claude/worktrees/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
